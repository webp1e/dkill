#!/bin/bash

DNS=$1
DOMAIN=$2

echo "DKILL - сканер DNS от unsecured"

# версия
echo -n "определение версии DNS-софта... "
version=$(dig version.bind. CHAOS TXT @"$DNS" +short 2>/dev/null | sed 's/"//g')

if [[ -n "$version" ]]; then
    echo "$version"
else
    echo "не удалось определить (сервер не раскрывает версию)"
fi



# резолв
echo -n "проверка открытого резолвера... "
res_c=$(dig @"$DNS" google.com +short 2>/dev/null)

if [[ -n "$res_c" ]]; then
    echo "$1 - открытый резолвер!"
    echo "   (Получен ответ для google.com: $res_c)"
else
    echo "$1 не является открытым резолвером"
fi



# з трансфер
echo -n "проверка зонного трансфера... "
axfr_o=$(dig axfr @"$DNS" "$DOMAIN" 2>/dev/null)

if echo "$axfr_o" | grep -q "ANSWER SECTION" && ! echo "$axfr_o" | grep -q "Transfer failed."; then
    echo "зонный трансфер возможен для домена $DOMAIN !"
    echo "   (Сервер выдал записи зоны)"
else
    echo "зонный трансфер запрещен"
fi

# днссек

dig @"$DNS" "$DOMAIN" DNSKEY +short

if [[ -n "$dnskey" ]]; then
    echo "DNSSEC настроен"
else
    echo "DNSSEC отсутствует"
fi

# птр

ptr=$(dig @"$DNS" -x "$DNS" +short 2>/dev/null)
if [[ -n "$ptr" ]]; then
    echo "PTR запись: $ptr"
else
    echo "PTR запись отсутствует"
fi

# спф

spf=$(dig @"$DNS" "$DOMAIN" TXT +short 2>/dev/null | grep "v=spf")
if [[ -z "$spf" ]]; then
    echo "SPF отсутствует — домен уязвим к email спуфингу"
else
    echo "SPF найден: $spf"
fi

# дмарс

dmarc=$(dig @"$DNS" "_dmarc.$DOMAIN" TXT +short 2>/dev/null)
if [[ -z "$dmarc" ]]; then
    echo "DMARC отсутствует"
else
    echo "DMARC: $dmarc"
fi

# мх

mx=$(dig @"$DNS" "$DOMAIN" MX +short 2>/dev/null)
if [[ -z "$mx" ]]; then
    echo "MX записи отсутствуют"
else
    echo "MX записи найдены:"
    echo "$mx" | while read line; do
        echo "   $line"
    done
fi

echo "аудит окончен..."
